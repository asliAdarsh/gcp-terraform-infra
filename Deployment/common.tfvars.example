# ======================================================================
# Common Configuration — REFERENCE ONLY
# ======================================================================
# Copy this to common.tfvars (gitignored) for local development.
# In CI/CD, these values come from GitHub Secrets as -var flags.
# ======================================================================

organization_id    = "your-organization_id"
billing_account_id = "your-billing_account_id"
state_bucket_name  = "tfstate-file-bucket-name"
region             = "asia-south1"
